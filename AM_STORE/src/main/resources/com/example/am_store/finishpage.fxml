<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="338.0" prefWidth="291.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.am_store.FinishPageController">
    <children>
        <Label layoutY="63.0" prefHeight="25.0" prefWidth="102.0" style="-fx-background-color: BLACK; -fx-background-radius: 20;" text="  Customer Name" textFill="WHITE">
            <font>
                <Font name="Bell MT Bold" size="12.0" />
            </font></Label>
        <TextField fx:id="nameField" layoutX="124.0" layoutY="63.0" />
        <TextField fx:id="phoneField" layoutX="124.0" layoutY="109.0" />
        <TextField fx:id="employeeIdField" layoutX="124.0" layoutY="150.0" />
        <Label fx:id="totalPriceLabel" layoutX="100" layoutY="200" />
        <ComboBox fx:id="statusComboBox" layoutX="123.0" layoutY="246.0" prefHeight="25.0" prefWidth="149.0">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Pending" />
                    <String fx:value="Completed" />
                    <String fx:value="Cancelled" />
                </FXCollections>
            </items>
        </ComboBox>
        <Button layoutX="100" layoutY="300" onAction="#handleSubmit" onMousePressed="#handleSubmit" style="-fx-background-color: black; -fx-background-radius: 20;" text="Submit" textFill="WHITE">
            <font>
                <Font name="Bell MT" size="14.0" />
            </font></Button>
        <TextField fx:id="orderIdField" layoutX="124.0" layoutY="17.0" />
        <Label layoutY="109.0" prefHeight="25.0" prefWidth="102.0" style="-fx-background-color: BLACK; -fx-background-radius: 20;" text="   Phone Number" textFill="WHITE">
            <font>
                <Font name="Bell MT Bold" size="12.0" />
            </font>
        </Label>
        <Label layoutY="17.0" prefHeight="25.0" prefWidth="102.0" style="-fx-background-color: BLACK; -fx-background-radius: 20;" text="      Order ID" textFill="WHITE">
            <font>
                <Font name="Bell MT Bold" size="12.0" />
            </font>
        </Label>
        <Label layoutY="150.0" prefHeight="25.0" prefWidth="102.0" style="-fx-background-color: BLACK; -fx-background-radius: 20;" text="   Employee ID" textFill="WHITE">
            <font>
                <Font name="Bell MT Bold" size="12.0" />
            </font>
        </Label>
        <Label layoutY="196.0" prefHeight="25.0" prefWidth="102.0" style="-fx-background-color: BLACK; -fx-background-radius: 20;" text="     Total Price" textFill="WHITE">
            <font>
                <Font name="Bell MT Bold" size="12.0" />
            </font>
        </Label>
        <Label layoutY="246.0" prefHeight="25.0" prefWidth="102.0" style="-fx-background-color: BLACK; -fx-background-radius: 20;" text="    Order Status" textFill="WHITE">
            <font>
                <Font name="Bell MT Bold" size="12.0" />
            </font>
        </Label>
    </children>
</AnchorPane>
