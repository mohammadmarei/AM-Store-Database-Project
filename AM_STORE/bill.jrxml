	<queryString language="SQL">
		<![CDATA[SELECT 
    o.order_id,
    o.employee_id,
    o.customer_name,
    o.customer_phone,
    o.total_price,
    o.status,
    o.date,
    p.name_product,
    od.quantity,
    od.price,
    (od.quantity * od.price) AS subtotal
FROM "Order" AS o
JOIN order_details AS od ON o.order_id = od.order_id
JOIN product AS p ON od.product_id = p.product_id]]>
	</queryString>
